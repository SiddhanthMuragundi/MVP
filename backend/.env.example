# Database
DATABASE_URL=postgresql+psycopg://tdc:tdc@localhost:5432/tdc

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# AES-256-GCM master key for encrypting stored LLM API keys.
# Provide 32 random bytes, base64-encoded. Generate one with:
#   python -c "import base64,os;print(base64.b64encode(os.urandom(32)).decode())"
# If left blank, a SHA-256-derived dev key is used (do not rely on this in production).
ENCRYPTION_KEY=

# CORS (comma-separated frontend origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Seeding
SEED_ON_STARTUP=true
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
MATCHMAKER_USERNAME=priya
MATCHMAKER_PASSWORD=priya123

# Optional default LLM (used only until an admin configures one in the app).
# Providers: openai | anthropic | gemini
LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
